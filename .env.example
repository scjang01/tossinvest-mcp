TOSSINVEST_API_KEY=
TOSSINVEST_SECRET_KEY=
TOSSINVEST_ACCOUNT=
TOSSINVEST_BASE_URL=

# Trading is disabled unless this is true.
TOSSINVEST_ENABLE_TRADING=

# --- Trading guardrails (conservative defaults shown) ---

# Require confirmOrderAction=true for create/modify/cancel.
TOSSINVEST_REQUIRE_ORDER_CONFIRMATION=true

# Single-order amount limits (per currency, no conversion).
TOSSINVEST_MAX_ORDER_AMOUNT_KRW=
TOSSINVEST_MAX_ORDER_AMOUNT_USD=

# Daily limits for orders submitted through this MCP (KST calendar day).
TOSSINVEST_DAILY_MAX_ORDER_AMOUNT_KRW=
TOSSINVEST_DAILY_MAX_ORDER_AMOUNT_USD=
TOSSINVEST_DAILY_MAX_ORDER_COUNT=

# Optional comma-separated symbol allowlist, e.g. 005930,AAPL,VOO
TOSSINVEST_ALLOWED_SYMBOLS=

# Sell and market-order controls.
TOSSINVEST_ALLOW_SELL_ORDERS=false
TOSSINVEST_ALLOW_MARKET_ORDERS=false
TOSSINVEST_MARKET_ORDER_BUFFER_PCT=5

# Reject tool input that targets a different account than TOSSINVEST_ACCOUNT.
TOSSINVEST_LOCK_ACCOUNT=true

# Optional guard state file override (defaults to the OS data directory).
TOSSINVEST_GUARD_STATE_PATH=
